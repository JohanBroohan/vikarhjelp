# --- Supabase ---------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values from your Supabase
# project: Supabase dashboard → Project Settings → API.
#
# These two are safe to expose to the browser (they are public by design):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SECRET — server only. Never prefix with NEXT_PUBLIC_, never commit the real
# value. Used by the seed script and trusted server code to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
